# Stable Portfolio Edition v1.0.0 requires none of these variables.
# They are optional placeholders for separately approved future integrations only.
# Copy only the variables required by that future integration into local environment
# configuration or Streamlit secrets. Never commit real credentials.

# Optional future OpenAI integration
OPENAI_API_KEY=

# Optional future Anthropic integration
ANTHROPIC_API_KEY=

# Optional future Google Gemini integration
GEMINI_API_KEY=

# Optional future external database integration
DATABASE_URL=
